// ── CONFETTI ───────────────────────────────────────────
function launchConfetti(col) {
  var c=document.getElementById('confetti');
  c.width=window.innerWidth; c.height=window.innerHeight; c.style.display='block';
  var cx=c.getContext('2d');
  var cols=[col,'#E8001C','#fff','#FF8C00','#ff69b4'];
  var parts=[];
  for(var i=0;i<120;i++) parts.push({x:Math.random()*c.width,y:-20,w:5+Math.random()*8,h:7+Math.random()*6,col:cols[Math.floor(Math.random()*cols.length)],vy:3+Math.random()*5,vx:(Math.random()-.5)*4,rot:Math.random()*360,rv:(Math.random()-.5)*10});
  var f=0;
  (function loop() {
    cx.clearRect(0,0,c.width,c.height);
    for(var i=0;i<parts.length;i++) {
      var p=parts[i]; p.y+=p.vy; p.x+=p.vx; p.rot+=p.rv;
      cx.save(); cx.translate(p.x,p.y); cx.rotate(p.rot*Math.PI/180);
      cx.fillStyle=p.col; cx.globalAlpha=Math.max(0,1-f/120);
      cx.fillRect(-p.w/2,-p.h/2,p.w,p.h); cx.restore();
    }
    f++; if(f<130) requestAnimationFrame(loop);
    else { cx.clearRect(0,0,c.width,c.height); c.style.display='none'; }
  })();
}

