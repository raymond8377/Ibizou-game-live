<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>IBIZOU</title>
<link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Boogaloo&family=Nunito:wght@700;900&display=swap" rel="stylesheet">
<style>
:root{--red:#E8001C;--gold:#FFD700;--orange:#FF8C00}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;user-select:none}
html,body{height:100%;font-family:'Nunito',sans-serif;color:#fff;overflow:hidden;
  background:radial-gradient(ellipse 80% 60% at 50% 0%,#2a0025 0%,#060612 65%)}
.star{position:fixed;z-index:0;border-radius:50%;background:#fff;pointer-events:none;animation:tw ease-in-out infinite}
@keyframes tw{0%,100%{opacity:.06}50%{opacity:.9}}
.screen{position:fixed;inset:0;z-index:10;display:flex;flex-direction:column;overflow:hidden}
.screen.hide{display:none}
.fixed-logo{position:fixed;top:.5rem;left:50%;transform:translateX(-50%);z-index:500;height:30px;cursor:pointer;filter:drop-shadow(0 0 8px rgba(232,0,28,.8))}
.cc{position:fixed;pointer-events:none;z-index:50;font-size:3rem;animation:cc 2.2s ease-in-out infinite;filter:drop-shadow(0 0 10px rgba(255,215,0,.9))}
.cc.tl{top:65px;left:5px;animation-delay:0s}
.cc.tr{top:65px;right:5px;animation-delay:.5s}
.cc.ml{top:40%;left:5px;animation-delay:1s}
.cc.mr{top:40%;right:5px;animation-delay:1.5s}
.cc.bl{bottom:85px;left:5px;animation-delay:.8s}
.cc.br{bottom:85px;right:5px;animation-delay:1.3s}
@keyframes cc{0%,100%{transform:scale(1) rotate(-6deg)}50%{transform:scale(1.2) rotate(6deg)}}

/* SPLASH */
#splash{align-items:center;justify-content:center;gap:.4rem;padding:2rem;text-align:center}
.s-title{font-family:'Pacifico',cursive;font-size:clamp(2.5rem,10vw,4rem);
  background:linear-gradient(135deg,var(--gold),var(--red),#fff);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  animation:glow 2.5s ease-in-out infinite}
@keyframes glow{0%,100%{filter:drop-shadow(0 0 12px rgba(232,0,28,.4))}50%{filter:drop-shadow(0 0 25px rgba(255,215,0,.9))}}
.s-logo{width:min(170px,52vw);filter:drop-shadow(0 0 18px rgba(232,0,28,.7));
  animation:flt 3s ease-in-out infinite;margin:.4rem 0}
@keyframes flt{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.s-sub{font-size:.72rem;color:rgba(255,255,255,.35);letter-spacing:3px;text-transform:uppercase;margin-bottom:1.5rem}
.play-btn{font-family:'Boogaloo',cursive;font-size:1.4rem;letter-spacing:3px;padding:1rem 3.5rem;
  border-radius:50px;border:none;color:#fff;cursor:pointer;
  background:linear-gradient(135deg,var(--red),#cc0015,var(--orange));
  box-shadow:0 5px 30px rgba(232,0,28,.55),0 0 0 2px rgba(255,215,0,.3);transition:transform .15s}
.play-btn:active{transform:scale(.95)}

/* GAME */
#game{background:transparent}
.top-bar{display:flex;align-items:center;justify-content:space-between;padding:.4rem 1rem;flex-shrink:0}
.b-dot{width:22px;height:22px;border-radius:50%;
  background:radial-gradient(circle at 35% 30%,#fff,var(--red),#880010);
  box-shadow:0 0 10px rgba(232,0,28,.7);transition:all .3s}
.b-dot.used{background:rgba(255,255,255,.1);box-shadow:none;transform:scale(.65)}
.score-txt{font-family:'Boogaloo',cursive;font-size:1.1rem;color:var(--gold)}
.game-body{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:space-evenly;padding:.3rem 1rem}
.wheel-wrap{position:relative;width:min(290px,78vw);height:min(290px,78vw);flex-shrink:0}
.wheel-glow{position:absolute;inset:-12px;border-radius:50%;background:conic-gradient(var(--red),var(--gold),var(--red));filter:blur(12px);opacity:.5;animation:sg 5s linear infinite}
@keyframes sg{to{transform:rotate(360deg)}}
#wheelCanvas{position:relative;z-index:2;border-radius:50%;display:block;width:100%;height:100%}
.ptr{position:absolute;top:-10px;left:50%;transform:translateX(-50%);z-index:10;filter:drop-shadow(0 0 5px var(--gold))}
.hub{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:10;
  width:42px;height:42px;border-radius:50%;border:none;
  background:radial-gradient(circle,#fff,var(--gold),var(--orange));
  font-family:'Boogaloo',cursive;font-size:.6rem;cursor:pointer;
  box-shadow:0 0 14px rgba(255,215,0,.7)}
.hub:disabled{opacity:.4}
.hub:active{transform:translate(-50%,-50%) scale(.9)}
#spinBtn{font-family:'Boogaloo',cursive;font-size:1.3rem;letter-spacing:2px;
  padding:.75rem 0;width:78%;max-width:250px;border-radius:50px;border:none;
  background:linear-gradient(135deg,var(--red),var(--orange),var(--gold));
  color:#0a0010;cursor:pointer;font-weight:900;
  box-shadow:0 4px 20px rgba(232,0,28,.55),0 0 0 3px rgba(255,215,0,.25)}
#spinBtn:disabled{opacity:.35;cursor:not-allowed}
#spinBtn:active{transform:scale(.95)}

/* RESULT */
#resultOv{position:fixed;inset:0;z-index:99997;background:rgba(0,0,0,.88);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s}
#resultOv.show{opacity:1;pointer-events:all}
.res-card{background:linear-gradient(160deg,#1a0030,#0d0020);border:2px solid var(--gold);border-radius:24px;padding:2rem 1.5rem;text-align:center;max-width:300px;width:88%;box-shadow:0 0 50px rgba(255,215,0,.3);animation:pop .5s cubic-bezier(.34,1.56,.64,1)}
@keyframes pop{from{transform:scale(.4);opacity:0}to{transform:scale(1);opacity:1}}
.res-logo{height:44px;margin-bottom:.5rem;filter:drop-shadow(0 0 8px rgba(232,0,28,.6))}
.res-emoji{font-size:3rem;display:block;margin-bottom:.3rem}
.res-won{font-size:.68rem;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.35);margin-bottom:.3rem}
.res-prize{font-family:'Boogaloo',cursive;font-size:clamp(1.6rem,7vw,2.3rem);background:linear-gradient(135deg,var(--gold),var(--red));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:.6rem}
.res-sub{font-size:.72rem;color:rgba(255,255,255,.3);margin-bottom:.4rem;line-height:1.5}
.res-close{font-family:'Boogaloo',cursive;font-size:.95rem;letter-spacing:2px;padding:.6rem 2rem;border-radius:50px;border:2px solid var(--red);background:rgba(232,0,28,.12);color:var(--red);cursor:pointer}
.res-replay{font-family:'Boogaloo',cursive;font-size:.95rem;letter-spacing:2px;padding:.6rem 1.5rem;border-radius:50px;border:none;background:linear-gradient(135deg,var(--red),var(--orange));color:#fff;cursor:pointer;margin-left:.5rem}

/* CONFIRM */
#confirmOv{position:fixed;inset:0;z-index:99999;background:rgba(0,0,0,.92);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s}
#confirmOv.show{opacity:1;pointer-events:all}
.conf-card{background:linear-gradient(160deg,#1a0030,#0d0020);border:2px solid var(--gold);border-radius:22px;padding:1.8rem 1.5rem;text-align:center;width:88%;max-width:300px;box-shadow:0 0 40px rgba(255,215,0,.3)}
.conf-prize{font-family:'Boogaloo',cursive;font-size:2.2rem;color:var(--gold);margin:.5rem 0}
.conf-sub{font-size:.72rem;color:rgba(255,255,255,.3);margin-bottom:1.2rem}
.conf-btns{display:flex;gap:.8rem;justify-content:center}
.conf-ok{font-family:'Boogaloo',cursive;font-size:1.1rem;padding:.7rem 1.8rem;border-radius:50px;border:none;background:linear-gradient(135deg,var(--red),var(--orange));color:#fff;cursor:pointer}
.conf-cancel{font-family:'Boogaloo',cursive;font-size:1rem;padding:.7rem 1.4rem;border-radius:50px;border:2px solid rgba(255,255,255,.2);background:rgba(255,255,255,.06);color:rgba(255,255,255,.6);cursor:pointer}

/* QR */
#qrOv{position:fixed;inset:0;z-index:99998;background:rgba(0,0,0,.92);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s;padding:1rem}
#qrOv.show{opacity:1;pointer-events:all}
.qr-card{background:linear-gradient(160deg,#1a0030,#0d0020);border:2px solid var(--red);border-radius:22px;padding:1.4rem;text-align:center;width:88%;max-width:300px;box-shadow:0 0 40px rgba(232,0,28,.4);margin:auto}
.qr-card h2{font-family:'Boogaloo',cursive;font-size:1.2rem;color:var(--gold);margin-bottom:.3rem}
.qr-info{font-family:'Boogaloo',cursive;font-size:.95rem;color:rgba(255,255,255,.5);margin-bottom:.5rem}
.qr-wrap{background:#fff;border-radius:12px;padding:8px;display:inline-block;margin-bottom:.8rem}
.qr-wrap img{width:200px;height:200px;display:block}
.qr-expire{font-size:.68rem;color:rgba(255,165,0,.75);margin-bottom:.8rem;font-weight:700}
.qr-close{font-family:'Nunito',sans-serif;font-weight:700;font-size:.82rem;padding:.5rem 1.8rem;border-radius:50px;border:1px solid rgba(255,255,255,.2);background:rgba(255,255,255,.07);color:rgba(255,255,255,.65);cursor:pointer}

/* USED */
#used{align-items:center;justify-content:center;text-align:center;padding:2rem}
.used-icon{font-size:3.5rem;margin-bottom:.8rem}
.used-title{font-family:'Boogaloo',cursive;font-size:2rem;color:#ff4444;margin-bottom:.5rem}
.used-sub{font-size:.82rem;color:rgba(255,255,255,.38);line-height:1.7}

/* PIN */
#pinModal{display:none;position:fixed;inset:0;z-index:999999;background:rgba(0,0,0,.92);align-items:center;justify-content:center}
.pin-card{background:linear-gradient(160deg,#1a0030,#0d0020);border:2px solid var(--red);border-radius:24px;padding:1.8rem 1.4rem;text-align:center;max-width:290px;width:88%}
.pin-dot{width:13px;height:13px;border-radius:50%;border:2px solid rgba(255,80,80,.5);display:inline-block;transition:background .15s;margin:0 .3rem}
.pin-dot.filled{background:var(--red);border-color:var(--red)}
.pin-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.45rem;margin:1rem 0 .4rem}
.pin-key{font-family:'Boogaloo',cursive;font-size:1.3rem;padding:.65rem;border-radius:10px;border:1px solid rgba(255,80,80,.2);background:rgba(255,255,255,.06);color:#fff;cursor:pointer}
.pin-key:active{background:rgba(232,0,28,.3);transform:scale(.92)}
.fb{position:fixed;top:45%;left:50%;transform:translate(-50%,-50%);font-family:'Boogaloo',cursive;font-size:1.3rem;padding:.55rem 1.4rem;border-radius:50px;background:rgba(0,0,0,.88);border:2px solid var(--gold);color:var(--gold);z-index:999999;pointer-events:none;animation:fb-out .8s ease forwards;white-space:nowrap}
@keyframes fb-out{0%{opacity:1;transform:translate(-50%,-50%) scale(1)}100%{opacity:0;transform:translate(-50%,-65%) scale(1.1)}}
#confetti{position:fixed;inset:0;pointer-events:none;z-index:9999;display:none}
</style>
</head>
<body>
<canvas id="confetti"></canvas>
<div id="starsDiv"></div>
<img class="fixed-logo" src="data:image/png;base64," alt="IBIZOU" onclick="logoTap()">
<div class="cc tl">💋</div><div class="cc tr">💋</div>
<div class="cc ml">🍀</div><div class="cc mr">💎</div>
<div class="cc bl">🎰</div><div class="cc br">💋</div>

<!-- SPLASH -->
<div class="screen" id="splash">
  <div class="s-title">IBIZOU</div>
  <img class="s-logo" src="data:image/png;base64," alt="IBIZOU">
  <div class="s-sub">💋 Roue de la Fortune 💋</div>
  <button class="play-btn" onclick="startFree()">💋 JOUER !</button>
</div>

<!-- GAME -->
<div class="screen hide" id="game">
  <div class="top-bar">
    <div style="display:flex;gap:.3rem" id="ballsRow"></div>
    <div class="score-txt" id="scoreTxt"></div>
  </div>
  <div class="game-body">
    <div class="wheel-wrap">
      <div class="wheel-glow"></div>
      <canvas id="wheelCanvas"></canvas>
      <svg class="ptr" width="26" height="34" viewBox="0 0 26 34">
        <polygon points="13,2 24,30 13,24 2,30" fill="#FFD700" stroke="#FF8C00" stroke-width="2" stroke-linejoin="round"/>
        <circle cx="13" cy="6" r="3.5" fill="#fff" opacity=".9"/>
      </svg>
      <button class="hub" id="hub" onclick="spin()">GO!</button>
    </div>
    <button id="spinBtn" onclick="spin()">💋 TOURNER 💋</button>
  </div>
</div>

<!-- USED -->
<div class="screen hide" id="used">
  <div class="used-icon">🚫</div>
  <div class="used-title">Deja utilise !</div>
  <div class="used-sub">Ce QR a deja ete utilise.<br>Demande un nouveau au gerant !</div>
</div>

<!-- RESULT -->
<div id="resultOv">
  <div class="res-card">
    <img class="res-logo" src="data:image/png;base64," alt="IBIZOU">
    <span class="res-emoji" id="resEmoji">🎉</span>
    <div class="res-won">Tu as gagne</div>
    <div class="res-prize" id="resPrize">-</div>
    <div class="res-sub">Montre au gerant pour ton prix !</div>
    <div style="margin-top:.8rem">
      <button class="res-close" onclick="closeResult()">SUPER !</button>
      <button class="res-replay" id="replayBtn" style="display:none" onclick="replay()">Rejouer</button>
    </div>
  </div>
</div>

<!-- CONFIRM -->
<div id="confirmOv">
  <div class="conf-card">
    <div style="font-size:.72rem;color:rgba(255,255,255,.4);letter-spacing:2px;text-transform:uppercase;margin-bottom:.3rem">Prix selectionne</div>
    <div class="conf-prize" id="confPrize">-</div>
    <div class="conf-sub">Verifie avant de montrer au client</div>
    <div class="conf-btns">
      <button class="conf-cancel" onclick="cancelConfirm()">Annuler</button>
      <button class="conf-ok" onclick="genQR()">Generer QR</button>
    </div>
  </div>
</div>

<!-- QR -->
<div id="qrOv">
  <div class="qr-card">
    <h2>Montre au client !</h2>
    <div class="qr-info" id="qrInfo"></div>
    <div class="qr-wrap"><img id="qrImg" width="200" height="200" alt="QR"></div>
    <div class="qr-expire" id="qrExpire"></div>
    <button class="qr-close" onclick="closeQR()">Fermer</button>
  </div>
</div>

<!-- PIN -->
<div id="pinModal">
  <div class="pin-card">
    <div style="font-size:1.8rem;margin-bottom:.4rem">🔐</div>
    <div style="font-family:'Boogaloo',cursive;font-size:1.3rem;color:var(--red);margin-bottom:.2rem">Acces Gerant</div>
    <div id="pinDots" style="margin-bottom:.9rem">
      <span class="pin-dot"></span><span class="pin-dot"></span><span class="pin-dot"></span><span class="pin-dot"></span>
    </div>
    <div class="pin-grid">
      <button class="pin-key" onclick="pk('1')">1</button><button class="pin-key" onclick="pk('2')">2</button><button class="pin-key" onclick="pk('3')">3</button>
      <button class="pin-key" onclick="pk('4')">4</button><button class="pin-key" onclick="pk('5')">5</button><button class="pin-key" onclick="pk('6')">6</button>
      <button class="pin-key" onclick="pk('7')">7</button><button class="pin-key" onclick="pk('8')">8</button><button class="pin-key" onclick="pk('9')">9</button>
      <button class="pin-key" style="color:var(--gold)" onclick="pkDel()">Del</button>
      <button class="pin-key" onclick="pk('0')">0</button>
      <button class="pin-key" style="font-size:.9rem" onclick="closePIN()">X</button>
    </div>
    <div id="pinErr" style="font-size:.72rem;color:#ff4444;height:.9rem"></div>
  </div>
</div>

<script>
// ── CONFIG ──────────────────────────────────────────────
var PIN = '2208';
var TTL = 5 * 60 * 1000;
var USED_KEY = 'ibizou_v5';

// ── PRIZES (NO EMOJI in labels = no encoding issues!) ──
var PRIZES = [
  {label:'PERDU',     color:'#1a0000', prob:10},
  {label:'PELUCHE',   color:'#E8001C', prob:5},
  {label:'PERDU',     color:'#2a0000', prob:10},
  {label:'12 BALLES', color:'#0066CC', prob:8},
  {label:'PERDU',     color:'#1a0000', prob:10},
  {label:'PETIT LOT', color:'#FFD700', prob:8},
  {label:'PERDU',     color:'#2a0000', prob:10},
  {label:'JACKPOT',   color:'#E8001C', prob:4},
  {label:'5 BALLES',  color:'#00AA44', prob:8},
  {label:'PERDU',     color:'#2a0000', prob:8},
  {label:'PELUCHE',   color:'#9900CC', prob:4},
  {label:'30 BALLES', color:'#ffffff', prob:6},
  {label:'PERDU',     color:'#1a0000', prob:7},
  {label:'PETIT LOT', color:'#00AACC', prob:5},
  {label:'PERDU',     color:'#2a0000', prob:7},
  {label:'1 PARTIE',  color:'#FF69B4', prob:2},
];

// Display names with emoji (for showing to client)
var DISPLAY = {
  'PERDU':     'PERDU',
  'PELUCHE':   'Peluche',
  '12 BALLES': '12 Balles',
  'PETIT LOT': 'Petit Lot',
  'JACKPOT':   'JACKPOT !',
  '5 BALLES':  '5 Balles',
  '30 BALLES': '30 Balles',
  '1 PARTIE':  '1 Partie Gratuite',
};

var EMOJIS = {
  'PERDU':     '😢',
  'PELUCHE':   '🧸',
  '12 BALLES': '🎱',
  'PETIT LOT': '🎁',
  'JACKPOT':   '🎰',
  '5 BALLES':  '⭐',
  '30 BALLES': '🎱',
  '1 PARTIE':  '🎮',
};

// ── STATE ──────────────────────────────────────────────
var forcedLabel = null;  // label to force (no emoji)
var token = null;
var spinning = false;
var spun = false;
var ang = 0;
var isFree = false;  // true when owner plays directly (no QR)

// ── NAVIGATION ─────────────────────────────────────────
function goTo(id) {
  var screens = document.querySelectorAll('.screen');
  for(var i=0;i<screens.length;i++) screens[i].classList.add('hide');
  document.getElementById(id).classList.remove('hide');
  if(id === 'game') setTimeout(resizeWheel, 60);
}

// ── TOKEN ──────────────────────────────────────────────
function checkToken() {
  var hash = window.location.hash.replace('#','');
  if(!hash) { goTo('splash'); return; }
  try {
    // Simple JSON token (no emoji in it!)
    var tok = JSON.parse(atob(hash));
    var id = tok.i;
    var exp = tok.e;
    var lbl = tok.l; // label without emoji
    if(exp && Date.now() > exp) { goTo('used'); return; }
    var used = getUsed();
    if(used[id]) { goTo('used'); return; }
    token = {id: id};
    forcedLabel = lbl;
    isFree = false;
    goTo('game');
    ablySend('game-open', {});
  } catch(e) { goTo('splash'); }
}

function getUsed() {
  try { return JSON.parse(localStorage.getItem(USED_KEY) || '{}'); }
  catch(e) { return {}; }
}
function markUsed(id) {
  var u = getUsed(); u[id] = Date.now();
  localStorage.setItem(USED_KEY, JSON.stringify(u));
}

// ── START FREE (owner plays directly) ──────────────────
function startFree() {
  token = null;
  isFree = true;
  // forcedLabel already set by logo tap (or null for random)
  goTo('game');
  ablySend('game-open', {});
}

// ── WHEEL ──────────────────────────────────────────────
var canvas = document.getElementById('wheelCanvas');
var ctx = canvas.getContext('2d');

function resizeWheel() {
  var s = canvas.parentElement.offsetWidth;
  canvas.width = s; canvas.height = s;
  drawWheel(ang);
}
window.addEventListener('resize', function() {
  if(!document.getElementById('game').classList.contains('hide')) resizeWheel();
});

function drawWheel(a) {
  var S=canvas.width, R=S/2-6, CX=S/2, CY=S/2;
  var n=PRIZES.length, sl=(2*Math.PI)/n;
  ctx.clearRect(0,0,S,S);
  
  for(var i=0;i<n;i++) {
    var s=a+i*sl, e=s+sl;
    ctx.beginPath(); ctx.moveTo(CX,CY); ctx.arc(CX,CY,R,s,e); ctx.closePath();
    ctx.fillStyle=PRIZES[i].color; ctx.fill();
    ctx.strokeStyle='rgba(255,215,0,0.6)'; ctx.lineWidth=2; ctx.stroke();
  }
  
  for(var i=0;i<n;i++) {
    var mid=a+i*sl+sl/2;
    ctx.save(); ctx.translate(CX,CY); ctx.rotate(mid);
    var fs=Math.max(8,Math.min(13,220/n/1.6));
    var p=PRIZES[i];
    var isLight=(p.color==='#ffffff'||p.color==='#FFD700'||p.color==='#00AACC'||p.color==='#00AA44');
    var isPerdu=(p.label==='PERDU');
    ctx.font='900 '+fs+'px Nunito,sans-serif';
    ctx.textAlign='right';
    ctx.shadowColor='rgba(0,0,0,1)'; ctx.shadowBlur=5;
    ctx.fillStyle=isPerdu?'#ff4444':(isLight?'#1a0000':'#FFD700');
    ctx.fillText(p.label, R-8, 5);
    ctx.restore();
  }
  
  // Shine
  var shine=ctx.createLinearGradient(CX-R*.8,CY-R*.8,CX+R*.3,CY+R*.3);
  shine.addColorStop(0,'rgba(255,255,255,0)');
  shine.addColorStop(.5,'rgba(255,255,255,.2)');
  shine.addColorStop(1,'rgba(255,255,255,0)');
  ctx.save(); ctx.beginPath(); ctx.arc(CX,CY,R,0,2*Math.PI); ctx.clip();
  ctx.fillStyle=shine; ctx.fillRect(CX-R,CY-R,R*2,R*2); ctx.restore();
  
  // Rim
  ctx.beginPath(); ctx.arc(CX,CY,R,0,2*Math.PI);
  ctx.strokeStyle='rgba(255,215,0,.9)'; ctx.lineWidth=4; ctx.stroke();
  
  // Hub
  var g=ctx.createRadialGradient(CX,CY,0,CX,CY,24);
  g.addColorStop(0,'#fff'); g.addColorStop(.45,'#FFD700'); g.addColorStop(1,'#E8001C');
  ctx.beginPath(); ctx.arc(CX,CY,24,0,2*Math.PI); ctx.fillStyle=g; ctx.fill();
  ctx.strokeStyle='rgba(255,215,0,.9)'; ctx.lineWidth=3; ctx.stroke();
  ctx.fillStyle='#1a0000'; ctx.font='bold 13px sans-serif';
  ctx.textAlign='center'; ctx.textBaseline='middle'; ctx.fillText('💋',CX,CY);
  ctx.textBaseline='alphabetic';
}

// ── PICK WINNER ────────────────────────────────────────
function pickWinner() {
  // If forced label set, find its index
  if(forcedLabel) {
    for(var i=0;i<PRIZES.length;i++) {
      if(PRIZES[i].label === forcedLabel) return i;
    }
  }
  // Random by probability
  var tot=0;
  for(var i=0;i<PRIZES.length;i++) tot+=PRIZES[i].prob;
  var r=Math.random()*tot;
  for(var i=0;i<PRIZES.length;i++) {
    r-=PRIZES[i].prob;
    if(r<=0) return i;
  }
  return PRIZES.length-1;
}

// ── SPIN ───────────────────────────────────────────────
function spin() {
  if(spinning||spun) return;
  spinning = true;
  document.getElementById('spinBtn').disabled = true;
  document.getElementById('hub').disabled = true;
  
  var winner = pickWinner();
  
  // Broadcast to TV
  ablySend('spin-start', {winnerIndex:winner, prize:PRIZES[winner].label});
  
  var n = PRIZES.length;
  var sl = (2*Math.PI)/n;
  
  // EXACT final angle: pointer at -PI/2 points to center of winner slice
  // winner slice center = winner*sl + sl/2
  // Need: ang_final + winner*sl + sl/2 = -PI/2 mod 2PI
  // So: ang_final = -PI/2 - winner*sl - sl/2
  var exactEnd = -Math.PI/2 - winner*sl - sl/2;
  
  // Add full rotations until targetAng > ang + 5 full turns
  var targetAng = exactEnd;
  while(targetAng < ang + 5*2*Math.PI) targetAng += 2*Math.PI;
  
  var dur = 4500;
  var t0 = performance.now();
  var a0 = ang;
  var delta = targetAng - a0;
  
  (function frame(now) {
    var t = Math.min((now-t0)/dur, 1);
    // Ease out quartic
    var ease = 1 - Math.pow(1-t, 4);
    ang = a0 + ease * delta;
    drawWheel(ang);
    if(t < 1) { requestAnimationFrame(frame); return; }
    // Force exact final position
    ang = targetAng;
    drawWheel(ang);
    spinning = false;
    spun = true;
    if(token && token.id) markUsed(token.id);
    showResult(winner);
  })(t0);
}

// ── RESULT ─────────────────────────────────────────────
function showResult(i) {
