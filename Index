  document.getElementById('resultOv').classList.add('show');
  if(lbl !== 'PERDU') launchConfetti('#FFD700');
}
function closeResult() {
  document.getElementById('resultOv').classList.remove('show');
  goTo('splash');
}
function replay() {
  spinning=false; spun=false; forcedLabel=null;
  document.getElementById('spinBtn').disabled=false;
  document.getElementById('hub').disabled=false;
  document.getElementById('resultOv').classList.remove('show');
  resizeWheel();
}

// ── QR GENERATION ──────────────────────────────────────
var pendingLabel = null;

function showConfirm(lbl, display) {
  pendingLabel = lbl;
  document.getElementById('confPrize').textContent = display;
  document.getElementById('confirmOv').classList.add('show');
}
function cancelConfirm() {
  document.getElementById('confirmOv').classList.remove('show');
  pendingLabel = null;
}
function genQR() {
  document.getElementById('confirmOv').classList.remove('show');
  var lbl = pendingLabel;
  pendingLabel = null;
  
  var tid = Math.random().toString(36).slice(2) + Date.now().toString(36);
  // Simple JSON - no emoji = no encoding issues!
  var tok = {i:tid, l:lbl, e:Date.now()+TTL};
  var encoded = btoa(JSON.stringify(tok));
  var url = window.location.href.split('#')[0] + '#' + encoded;
  
  document.getElementById('qrInfo').textContent = '';
  var img = document.getElementById('qrImg');
  img.src = 'https://quickchart.io/qr?text=' + encodeURIComponent(url) + '&size=200&margin=1';
  img.onerror = function() {
    img.src = 'https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=' + encodeURIComponent(url);
  };
  
  var rem = Math.floor(TTL/1000);
  var el = document.getElementById('qrExpire');
  el.textContent = 'Valide ' + fmt(rem);
  clearInterval(window._qt);
  window._qt = setInterval(function() {
    rem--;
    el.textContent = rem>0 ? 'Valide '+fmt(rem) : 'Expire';
    if(rem<=0) clearInterval(window._qt);
  }, 1000);
  
  document.getElementById('qrOv').classList.add('show');
}
function closeQR() { document.getElementById('qrOv').classList.remove('show'); }
function fmt(s) { return Math.floor(s/60)+':'+(s%60<10?'0':'')+(s%60); }

